# Copy to .env (which is gitignored) and fill in. NEVER commit the real .env.

# OpenRouter (categorisation). Free-tier key. Disable data retention in your OpenRouter account.
# NOTE: the names below are recommendations; CONFIRM the exact slug by copying each
# model's ID from its page on openrouter.ai (display name != API slug).
OPENROUTER_API_KEY=
# Default: Qwen3 Next 80B A3B Instruct (fast MoE, strong JSON/instruction-following)
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# Fallback: Google Gemma 4 31B (different family, reliable) — used on error/429/bad-JSON
OPENROUTER_FALLBACK_MODEL=google/gemma-4-31b-it:free
# Last resort: OpenRouter's free auto-router (picks any available free model)
OPENROUTER_ROUTER_FALLBACK=openrouter/free

# OpenRouter base URL — optional; defaults to https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional HTTP headers sent with every OpenRouter request (leave blank to omit)
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=

# Google Drive service account (path to the JSON key file; the file itself is gitignored)
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
DRIVE_FOLDER_ID=

# Local paths
OUTPUT_DIR=./output
SQLITE_PATH=./data/financetracker.sqlite
LOG_DIR=./logs

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8010
# Extra origins allowed to call the API (comma-separated). Set your tailnet URL
# here for phone access, e.g. https://<machine>.<tailnet>.ts.net
CORS_ALLOW_ORIGINS=

# Web Push notifications (v2 Pass 3) - SCAFFOLD, OFF by default.
# Leave PUSH_ENABLED=false and keys blank to keep the feature inert (no push service is
# contacted). To activate: install pywebpush (`pip install pywebpush`), generate a VAPID
# key pair (e.g. `python -m py_vapid` or `vapid --gen`), paste the keys below, set a
# subject (mailto:you@example.com or https://your-origin), and set PUSH_ENABLED=true.
# NEVER commit real keys.
PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
