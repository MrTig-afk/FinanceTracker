# Copy to .env (which is gitignored) and fill in. NEVER commit the real .env.

# OpenRouter (categorisation). Free-tier key. Disable data retention in your OpenRouter account.
# NOTE: the names below are recommendations; CONFIRM the exact slug by copying each
# model's ID from its page on openrouter.ai (display name != API slug).
OPENROUTER_API_KEY=
# Default: Qwen3 Next 80B A3B Instruct (fast MoE, strong JSON/instruction-following)
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# Fallback: Google Gemma 4 31B (different family, reliable) — used on error/429/bad-JSON
OPENROUTER_FALLBACK_MODEL=google/gemma-4-31b-it:free
# Last resort: OpenRouter's free auto-router (picks any available free model)
OPENROUTER_ROUTER_FALLBACK=openrouter/free

# Google Drive service account (path to the JSON key file; the file itself is gitignored)
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
DRIVE_FOLDER_ID=

# Local paths
INBOX_DIR=./data/inbox
OUTPUT_DIR=./output
SQLITE_PATH=./data/financetracker.sqlite
LOG_DIR=./logs

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
