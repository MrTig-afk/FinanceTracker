# Frontend environment variables — SAFE, non-secret.
# Copy to .env for local overrides (the .env file itself is gitignored).
# No API keys, no credentials, no secrets belong in this file or in any frontend file.

VITE_API_BASE=http://localhost:8000

# Web Push public key (v2 Pass 3). SAFE, non-secret (public half only).
# Placeholder keeps the "Enable notifications" button in a disabled "not configured"
# state. Replace with the VAPID PUBLIC key that matches the backend's VAPID_PUBLIC_KEY.
VITE_VAPID_PUBLIC_KEY=REPLACE_WITH_VAPID_PUBLIC_KEY
